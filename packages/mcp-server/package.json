{
	"name": "@e-shiwake/mcp-server",
	"version": "0.1.1",
	"description": "e-shiwake MCP server - AI-powered accounting tools via Model Context Protocol",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"e-shiwake-mcp-server": "dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"start": "node dist/index.js",
		"build": "tsc",
		"clean": "rm -rf dist *.tsbuildinfo",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@e-shiwake/core": "workspace:*",
		"@e-shiwake/db": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.12.1",
		"zod": "^3.24.4"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"typescript": "^5.7.2",
		"vitest": "^1.0.0"
	},
	"engines": {
		"node": ">=18"
	}
}
