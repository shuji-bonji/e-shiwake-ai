{
	"name": "@e-shiwake/db",
	"version": "0.1.0",
	"description": "e-shiwake database layer - SQLite repositories for accounting data",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"clean": "rm -rf dist *.tsbuildinfo",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@e-shiwake/core": "workspace:*",
		"better-sqlite3": "^11.8.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.10.0",
		"typescript": "^5.7.2",
		"vitest": "^2.0.0"
	}
}
